# Supabase — create a project at https://supabase.com and copy these from
# Project Settings → API. Then duplicate this file to `.env` and fill in.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Company details used on invoices / branding
VITE_COMPANY_NAME=Viziotec
VITE_COMPANY_EMAIL=hello@viziotec.com
VITE_COMPANY_PHONE=+62 000 0000 0000
VITE_COMPANY_ADDRESS=Jakarta, Indonesia
